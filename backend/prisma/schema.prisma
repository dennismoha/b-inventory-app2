//all products in our system from purchase , total will be stored here. 
model ProductSummary {
  product_summary_id   String           @id @default(uuid())
  supplier_products_id String           @unique @db.Uuid
  total_received       Int              @default(0)
  total_sold           Int              @default(0)
  reorder_level        Int              @default(0)
  total_cost_value     Decimal
  supplierProduct      SupplierProducts @relation(fields: [supplier_products_id], references: [supplier_products_id])
}

model PartialPurchasePayment {
  partial_purchase_id String        @id @default(uuid()) @db.Uuid
  purchase_id         String        @db.Uuid
  full_amount         Decimal       @db.Decimal(12, 2)
  initial_payment     Decimal       @db.Decimal(12, 2)
  balance             Decimal       @db.Decimal(12, 2)
  payment_method      PaymentMethod
  payment_date        DateTime      @default(now())
  created_at          DateTime      @default(now())

  Purchase Purchase            @relation(fields: [purchase_id], references: [purchase_id])
  Logs     PartialPaymentLog[]
}

model PartialPaymentLog {
  id                 String        @id @default(uuid()) @db.Uuid
  partial_payment_id String        @db.Uuid
  initial_payment    Decimal       @db.Decimal(12, 2)
  amount_paid        Decimal       @db.Decimal(12, 2)
  payment_date       DateTime      @default(now())
  payment_method     PaymentMethod

  PartialPayment PartialPurchasePayment @relation(fields: [partial_payment_id], references: [partial_purchase_id])
}

// 3. Purchase Expenses Table - Additional costs linked to batch
model PurchaseExpense {
  expense_id           String   @id @default(uuid()) @db.Uuid
  purchase_id          String   @db.Uuid
  // batch_id          String    @db.Uuid
  supplier_products_id String   @db.Uuid
  expense_type         String // transport, offloading, storage, customs, etc.
  amount               Decimal  @db.Decimal(12, 2)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  // batch             Batch     @relation(fields: [batch_id], references: [batch_id])
  // supplierProduct   SupplierProducts @relation(fields: [supplier_products_id], references: [supplier_products_id])
  purchase Purchase @relation(fields: [purchase_id], references: [purchase_id])

  @@map("PurchaseExpense")
}

// 4. Purchase Damages Table - Track damaged units per batch
model PurchaseDamage {
  damage_id   String   @id @default(uuid()) @db.Uuid
  purchase_id String   @db.Uuid
  // supplier_products_id String  @db.Uuid
  quantity    Int
  reason      String
  damage_date DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // batch            Batch     @relation(fields: [batch_id], references: [batch_id])
  // supplierProduct  SupplierProducts @relation(fields: [supplier_products_id], references: [supplier_products_id])
  purchase Purchase @relation(fields: [purchase_id], references: [purchase_id], onDelete: Cascade)

  @@map("PurchaseDamage")
}

// 5. Batch Inventory Table - Available stock after damages and sales
model BatchInventory {
  batch_inventory_id   String               @id @default(uuid()) @db.Uuid
  // batch_id           String   @unique @db.Uuid
  purchase_id          String               @unique @db.Uuid
  total_units          Int
  batch_name           String               @unique
  // damaged_units      Int
  status               BatchInventoryStatus @default(PENDING) // ACTIVE,PENDING, INACTIVE, DISCONTINUED
  supplier_products_id String               @db.Uuid
  // units_sold         Int
  // available_units    Int      // calculated as total_units - damaged_units - units_sold
  updated_at           DateTime             @updatedAt
  created_at           DateTime             @default(now())

  // batch              Batch    @relation(fields: [batch_id], references: [batch_id])
  purchase Purchase @relation(fields: [purchase_id], references: [purchase_id], onDelete: Cascade)

  // BatchInventory Inventory[]
  BatchLifeCycle BatchLifecycle[]

  @@map("BatchInventory")
}

model BatchLifecycle {
  id         String    @id @default(uuid())
  batch_id   String    @unique @db.Uuid
  started_at DateTime  @default(now())
  ended_at   DateTime?

  // Relations
  batch BatchInventory @relation(fields: [batch_id], references: [batch_inventory_id])
}

// 6. Batch Payables Table - Credit purchase tracking per batch
model BatchPayables {
  payable_id      String        @id @default(uuid()) @db.Uuid
  purchase_id     String        @unique @db.Uuid
  amount_due      Decimal       @db.Decimal(12, 2)
  total_paid      Decimal       @default(0.00) @db.Decimal(12, 2) // Total amount paid so far
  status          PayableStatus
  payment_type    PaymentType
  balance_due     Decimal       @default(0.00) @db.Decimal(12, 2) // Remaining balance if partially paid
  settlement_date DateTime?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  batchpayable Purchase @relation(fields: [purchase_id], references: [purchase_id])

  @@map("BatchPayables")
}

model CashBookLedger {
  ledger_id                  String          @id @default(uuid())
  opening_closing_balance_id String          @db.Uuid
  transaction_date           DateTime        @default(now())
  transaction_type           TransactionType
  amount                     Decimal         @db.Decimal(12, 2)
  method                     PaymentMethod
  reference_type             ReferenceType
  reference_id               String?         @db.Uuid // Can be null if no specific reference
  balance_after              Decimal?        @default(0.00) @db.Decimal(14, 2)
  description                String?
  created_at                 DateTime        @default(now())
  updated_at                 DateTime        @updatedAt

  // Relations
  account_id  String  @db.Uuid
  AccountInfo Account @relation(fields: [account_id], references: [account_id])

  // Linked to OpeningClosingBalance session
  openingClosingBalance OpeningClosingBalance? @relation(fields: [opening_closing_balance_id], references: [cash_bank_ledger_id])

  // TerminalSessionId Int? // Nullable if not linked to a terminal session
}

model Account {
  account_id      String        @id @default(uuid()) @db.Uuid()
  name            String
  account_number  String        @unique
  type            AccountType // Asset, Liability, Equity, Income, Expense
  opening_balance Decimal       @default(0.00) @db.Decimal(14, 2)
  running_balance Decimal       @default(0.00) @db.Decimal(14, 2)
  deleted         Boolean       @default(false) // Soft delete flag
  account_status  AccountStatus @default(ACTIVE) // ACTIVE, INACTIVE, CLOSED
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  AssetRegister    AssetRegister[]
  Purchase         Purchase[] // Purchases made through this account
  // Relations
  AccountInfo      CashBookLedger[]
  AccountBalances  AccountBalanceSnapshot[]
  AccountStatusLog AccountStatusLog[]
  ExpenseAccounts  Expense[]
  // OpeningClosingBalance OpeningClosingBalance[]
  // @@unique([name, type])
  journalLines     JournalLine[]
}

model JournalEntry {
  entry_id      String        @id @default(uuid())
  transactionId String
  date          DateTime      @default(now())
  description   String
  lines         JournalLine[]
}

model JournalLine {
  line_id    String  @id @default(uuid())
  entry_id   String
  account_id String  @db.Uuid
  debit      Decimal @default(0.00) @db.Decimal(14, 2)
  credit     Decimal @default(0.00) @db.Decimal(14, 2)

  account Account      @relation(fields: [account_id], references: [account_id])
  journal JournalEntry @relation(fields: [entry_id], references: [entry_id])
}

//Log Account status change for each account. from Active, inActive etc created
model AccountStatusLog {
  id             String         @id @default(uuid())
  account_id     String         @db.Uuid
  old_status     AccountStatus? // old status can be empty before it gets created
  new_status     AccountStatus
  pos_session_id String
  changed_by     String
  changed_at     DateTime       @default(now())

  // Relations
  account Account @relation(fields: [account_id], references: [account_id], onDelete: Cascade)

  @@map("account_status_log")
}

// for each pos_end session the opening and closing balnce of each account is recorded
model AccountSessionLog {
  id              String   @id @default(cuid())
  account_id      String
  opening_balance Decimal
  closing_balance Decimal
  pos_session     String
  user            String
  created_at      DateTime @default(now())

  @@map("account_session_log") // Optional: map to table name if needed
}

// for each activity done to the acccount, debit or credit it is recorded here.
model AccountsLog {
  accounts_log_id     String   @id @default(cuid())
  account_id          String
  action              String // 'debit' | 'credit'
  opening_balance     Decimal
  old_running_balance Decimal
  new_running_balance Decimal
  pos_session_id      String
  user                String
  created_at          DateTime @default(now())

  @@map("accounts_log") // Optional: use this if your table name in DB is different
}

model Employee {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  email      String   @unique
  phone      String?
  department String?
  position   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relation: one employee can have many assets
  assets AssetRegister[]
}

model AssetRegister {
  id              String   @id @default(uuid())
  assetTag        String   @unique
  name            String
  description     String?
  purchaseDate    DateTime
  purchaseCost    Float
  supplier        String?
  location        String?
  status          String   @default("active") // active, under_maintenance, disposed
  depreciation    Float?
  usefulLifeYears Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accountId String?       @db.Uuid
  account   Account?      @relation(fields: [accountId], references: [account_id])
  category  AssetCategory

  // Relation: optional custodian
  custodianId String?
  custodian   Employee? @relation(fields: [custodianId], references: [id])
}

// Enums for your new tables
enum PaymentType {
  full
  partial
  credit
}

enum PayableStatus {
  settled
  unsettled
}

model User {
  user_id  String @id @default(uuid())
  username String
  email    String @unique
  password String

  role      UserRoles
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  UserLoginLog     UserLoginLog[]
  userLoginAttempt UserLoginAttempt[]
  PosSessionOpened PosSession[]       @relation("OpenedSessions")
  PosSessionClosed PosSession[]       @relation("ClosedSessions")
}

model UserLoginLog {
  id         Int       @id @default(autoincrement())
  userId     String
  terminalId String
  loginTime  DateTime  @default(now())
  logoutTime DateTime?
  isLoggedIn Boolean   @default(false)

  user User @relation(fields: [userId], references: [user_id])
}

model UserLoginAttempt {
  id          Int      @id @default(autoincrement())
  userId      String
  attemptTime DateTime
  ipAddress   String
  userAgent   String
  status      String // e.g., 'FAILED_ACTIVE_SESSION', 'WRONG_PASSWORD'
  user        User     @relation(fields: [userId], references: [user_id])
}

model PosSession {
  pos_session_id String                @id @default(uuid())
  posId          String
  openedBy       String
  openedAt       DateTime              @default(now())
  closedBy       String?
  closedAt       DateTime?
  status         TerminalSessionStatus @default(CLOSED)
  createdAt      DateTime              @default(now())

  openedUser User                    @relation("OpenedSessions", fields: [openedBy], references: [email], onDelete: Cascade)
  closedUser User?                   @relation("ClosedSessions", fields: [closedBy], references: [email], onDelete: Cascade)
  balances   OpeningClosingBalance[]
  // ledgerEntries CashBookLedger[]
}

model OpeningClosingBalance {
  id                  String        @id @default(uuid()) @db.Uuid
  pos_session_id      String
  cash_bank_ledger_id String        @unique @db.Uuid // Nullable if not linked to a specific cash bank ledger
  opening_date        DateTime      @default(now())
  closing_date        DateTime?
  status              SessionStatus @default(PREV) // e.g. PREV, CLOSED
  opening_balance     Decimal       @db.Decimal(14, 2)
  closing_balance     Decimal?      @db.Decimal(14, 2)
  total_for_accounts  Decimal?      @db.Decimal(14, 2)

  // Link to account snapshot
  account_collection_id String?            @db.Uuid
  accountCollection     AccountCollection? @relation(fields: [account_collection_id], references: [collection_id])
  cashBookLedgers       CashBookLedger[]
  session               PosSession         @relation(fields: [pos_session_id], references: [pos_session_id])
  // account         Account   @relation(fields: [accountId], references: [account_id])
}


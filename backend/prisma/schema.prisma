// Enum to represent the possible statuses of the inventory item
enum InventoryStatus {
  ACTIVE // Item is available for sale and can be interacted with.
  INACTIVE // Item is temporarily unavailable for sale, could be out of stock or on hold.
  DISCONTINUED // Item is no longer available for sale and will not be restocked.
  FINISHED
}

enum BatchInventoryStatus {
  ACTIVE // Item is available for sale and can be interacted with.
  INACTIVE // Item is temporarily unavailable for sale, could be out of stock or on hold.
  DISCONTINUED // Item is no longer available for sale and will not be restocked.
  FINISHED // that batch is done being sold
  PENDING // all other batches that are not being sold at the moment.
}

enum AccountStatus {
  ACTIVE // Account is active and can be used for transactions.
  INACTIVE // Account is inactive, cannot be used for transactions.
  CLOSED // Account is closed and cannot be used for any transactions.
  CREATED
}

